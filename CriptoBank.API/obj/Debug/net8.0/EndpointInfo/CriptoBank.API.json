    "/api/Wallet/deposito": {
      "post": {
        "tags": [
          "Wallet"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdicionarSaldoCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AdicionarSaldoCommand"
