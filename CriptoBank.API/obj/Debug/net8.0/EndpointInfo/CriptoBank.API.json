    "/api/Wallet/buy": {
      "post": {
        "tags": [
          "Wallet"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BuyCryptoCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/BuyCryptoCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/BuyCryptoCommand"
              }
